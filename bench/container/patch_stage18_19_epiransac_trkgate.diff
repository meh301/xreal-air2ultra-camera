+  /* XR_EPIRANSAC (stage 18): IMU-rotation-prior temporal epipolar gate on cam0.
+   * Reuses the gyro/IMU-driven relative pose T_c1_c2 (prev<-curr) as a fixed
+   * rotation prior R. For every cam0 track present in both prev and curr frame
+   * we predict where the previous feature *should* land in the current image
+   * under pure rotation (rotation-compensated reprojection: f_c2 = R^T f_c1).
+   * The residual parallax vector must point at a single focus-of-expansion
+   * (the epipole implied by the translation). A 2-point RANSAC over the
+   * parallax lines finds that epipole; tracks whose parallax deviates from it
+   * by more than XR_EPIRANSAC_PX pixels are geometrically impossible given the
+   * measured rotation (classic motion-blur mistrack) and are removed. Degrades
+   * to a no-op under near-pure-rotation: skipped when |t| < XR_EPIRANSAC_TMIN
+   * metres. Removal pattern mirrors filterPointsForCam. */
+  void xrEpiRansacFilter(const Keypoints& prev_kpts, Keypoints& curr_kpts,
+                         const SE3& T_c1_c2, size_t cam_id) const {
+    // (1) Near-pure-rotation guard: skip if measured translation is tiny.
+    const double t_norm = T_c1_c2.translation().template cast<double>().norm();
+    if (t_norm < xr_epiransac_tmin()) return;
+
+    // (2) Gather matched tracks; rotation-compensate previous bearings forward
+    //     into the current frame (pure-rotation prediction).
+    const Eigen::Matrix<Scalar, 3, 3> R = T_c1_c2.so3().matrix();  // c2 -> c1
+    std::vector<KeypointId> ids;
+    Eigen::aligned_vector<Eigen::Vector2f> prev_px, curr_px;
+    ids.reserve(curr_kpts.size());
+    prev_px.reserve(curr_kpts.size());
+    curr_px.reserve(curr_kpts.size());
+    for (const auto& [kpid, affine] : curr_kpts) {
+      auto it = prev_kpts.find(kpid);
+      if (it == prev_kpts.end()) continue;
+      ids.push_back(kpid);
+      prev_px.emplace_back(it->second.translation());
+      curr_px.emplace_back(affine.translation());
+    }
+    if (ids.size() < 12) return;  // too few to estimate an epipole robustly
+
+    Eigen::aligned_vector<Eigen::Vector4f> f_prev;
+    std::vector<bool> up_ok;
+    calib.intrinsics[cam_id].unproject(prev_px, f_prev, up_ok);
+
+    Eigen::aligned_vector<Eigen::Vector4f> f_prev_in_curr(f_prev.size());
+    for (size_t i = 0; i < f_prev.size(); i++) {
+      f_prev_in_curr[i] = f_prev[i];
+      f_prev_in_curr[i].template head<3>() = R.transpose() * f_prev[i].template head<3>();
+    }
+    Eigen::aligned_vector<Eigen::Vector2f> pred_px;
+    std::vector<bool> pr_ok;
+    calib.intrinsics[cam_id].project(f_prev_in_curr, pred_px, pr_ok);
+
+    // (3) Build parallax constraints (current-image pixels). d is the actual
+    //     (unnormalized) parallax vector after rotation compensation; only
+    //     tracks with parallax above the residual scale are judged/removable.
+    const float px_thr = xr_epiransac_px();
+    const float d_min2 = (2.0f * px_thr) * (2.0f * px_thr);
+    Eigen::aligned_vector<Eigen::Vector2f> P, D;  // anchor point, parallax vec
+    std::vector<size_t> idx;                      // back-reference into ids
+    P.reserve(ids.size());
+    D.reserve(ids.size());
+    idx.reserve(ids.size());
+    for (size_t i = 0; i < ids.size(); i++) {
+      if (!up_ok[i] || !pr_ok[i]) continue;
+      Eigen::Vector2f d = curr_px[i] - pred_px[i];
+      if (d.squaredNorm() < d_min2) continue;  // low parallax: ambiguous, never remove
+      P.push_back(pred_px[i]);
+      D.push_back(d);
+      idx.push_back(i);
+    }
+    const size_t n = P.size();
+    if (n < 8) return;  // too few constrained tracks -> trust nothing, remove nothing
+
+    // Epipolar residual (pixels): the parallax component of track i that is
+    // perpendicular to the epipolar direction (P[i] -> epipole e). This is
+    // |d_i x Lhat|, bounded by |d_i|, so it is a genuine pixel residual and
+    // does NOT blow up with distance to the (possibly far) epipole.
+    auto epi_resid = [&](const Eigen::Vector2f& e, size_t i) -> float {
+      Eigen::Vector2f L = e - P[i];
+      const float Ln = L.norm();
+      if (Ln < 1e-6f) return 0.f;  // at the epipole: degenerate -> treat as inlier
+      L /= Ln;
+      return std::abs(D[i].x() * L.y() - D[i].y() * L.x());
+    };
+
+    // (4) 2-point RANSAC for the focus-of-expansion (epipole): intersect the
+    //     parallax lines of two tracks, score every track by epi_resid.
+    std::mt19937 rng(12345u);
+    std::uniform_int_distribution<size_t> pick(0, n - 1);
+    int best_inliers = -1;
+    Eigen::Vector2f best_e(0, 0);
+    for (int it = 0; it < 100; it++) {
+      size_t a = pick(rng), b = pick(rng);
+      if (a == b) continue;
+      const float det = D[a].x() * (-D[b].y()) - (-D[b].x()) * D[a].y();
+      if (std::abs(det) < 1e-3f) continue;  // near-parallel lines -> epipole ill-conditioned
+      const Eigen::Vector2f rhs = P[b] - P[a];
+      const float s = (rhs.x() * (-D[b].y()) - (-D[b].x()) * rhs.y()) / det;
+      const Eigen::Vector2f e = P[a] + s * D[a];
+      int inliers = 0;
+      for (size_t i = 0; i < n; i++)
+        if (epi_resid(e, i) <= px_thr) inliers++;
+      if (inliers > best_inliers) { best_inliers = inliers; best_e = e; }
+    }
+
+    if (getenv("XR_EPIRANSAC_DEBUG")) {
+      static int dbgn = 0;
+      if (dbgn < 60) { dbgn++;
+        float mp = 0; for (size_t i = 0; i < n; i++) mp += D[i].norm(); mp /= n;
+        std::vector<float> rr(n); for (size_t i = 0; i < n; i++) rr[i] = epi_resid(best_e, i);
+        std::nth_element(rr.begin(), rr.begin() + n / 2, rr.end());
+        std::cerr << "[xr-epi] n=" << n << " inl=" << best_inliers
+                  << " ratio=" << (n ? (float)best_inliers / n : 0.f)
+                  << " medresid=" << rr[n / 2] << " meanpar=" << mp
+                  << " |t|=" << t_norm << " thr=" << px_thr << std::endl;
+      }
+    }
+
+    // (5) Fail-safe: if even the best epipole explains too few tracks, the
+    //     rotation prior / geometry is unreliable this frame -> remove nothing.
+    if (best_inliers < 0 || (float)best_inliers < 0.5f * (float)n) return;
+
+    // (6) Remove tracks whose rotation-compensated epipolar residual exceeds
+    //     the threshold (mirrors filterPointsForCam removal).
+    for (size_t i = 0; i < n; i++)
+      if (epi_resid(best_e, i) > px_thr) curr_kpts.erase(ids[idx[i]]);
+  }
