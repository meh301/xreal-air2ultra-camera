+        T_w_i_init.setQuaternion(Eigen::Quaternion<Scalar>::FromTwoVectors(xr_grav_accel, Vec3::UnitZ()));
 
         last_state_t_ns = curr_frame->t_ns;
         imu_meas[last_state_t_ns] = IntegratedImuMeasurement<Scalar>(last_state_t_ns, bg, ba);
