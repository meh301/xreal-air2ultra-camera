<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:keepScreenOn="true"
    android:orientation="vertical">

    <!-- top half: vSLAM tracking (left) | stereo depth (right) -->
    <ImageView
        android:id="@+id/preview"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:contentDescription="@string/app_name"
        android:scaleType="fitCenter" />

    <!-- bottom half: 3D pose / map of the headset -->
    <org.air2ultra.stereocam.PoseMapView
        android:id="@+id/pose_map"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="2dp"
        android:layout_weight="2" />

    <!-- the general log line is drawn along the bottom of the 3D viewer;
         the full row width belongs to the buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#88000000"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="4dp"
        android:paddingTop="4dp">

        <Button
            android:id="@+id/slam_reset"
            style="@style/ThinButton"
            android:text="@string/slam_reset" />

        <Button
            android:id="@+id/toggle_points"
            style="@style/ThinButton"
            android:text="@string/pts_on" />

        <Button
            android:id="@+id/toggle_depth"
            style="@style/ThinButton"
            android:text="@string/dep_on" />

        <Button
            android:id="@+id/pane_mode"
            style="@style/ThinButton"
            android:text="@string/pane_ldep" />

        <Button
            android:id="@+id/snapshot"
            style="@style/ThinButton"
            android:text="@string/snapshot" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#88000000"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="4dp"
        android:paddingBottom="4dp">

        <Button
            android:id="@+id/map_mode"
            style="@style/ThinButton"
            android:text="@string/map_on" />

        <Button
            android:id="@+id/graph_mode"
            style="@style/ThinButton"
            android:text="@string/graph_on" />

        <Button
            android:id="@+id/prop_mode"
            style="@style/ThinButton"
            android:text="@string/prop_on" />

        <Button
            android:id="@+id/eye_mode"
            style="@style/ThinButton"
            android:text="@string/eye_cam" />

        <Button
            android:id="@+id/view_mode"
            style="@style/ThinButton"
            android:text="@string/mode_sbs" />
    </LinearLayout>
</LinearLayout>
