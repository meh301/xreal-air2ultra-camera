<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:keepScreenOn="true"
    android:orientation="vertical">

    <!-- top half: vSLAM tracking (left) | stereo depth (right) -->
    <ImageView
        android:id="@+id/preview"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:contentDescription="@string/app_name"
        android:scaleType="fitCenter" />

    <!-- bottom half: 3D pose / map of the headset -->
    <org.air2ultra.stereocam.PoseMapView
        android:id="@+id/pose_map"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="2dp"
        android:layout_weight="2" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#88000000"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="4dp">

        <TextView
            android:id="@+id/status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:fontFamily="monospace"
            android:maxLines="1"
            android:text="@string/status_plug_in"
            android:textColor="#00FF66"
            android:textSize="12sp" />

        <Button
            android:id="@+id/slam_reset"
            style="@style/ThinButton"
            android:text="@string/slam_reset" />

        <Button
            android:id="@+id/toggle_points"
            style="@style/ThinButton"
            android:text="@string/pts_on" />

        <Button
            android:id="@+id/toggle_depth"
            style="@style/ThinButton"
            android:text="@string/dep_on" />

        <Button
            android:id="@+id/toggle_cam"
            style="@style/ThinButton"
            android:text="@string/cam_on" />

        <Button
            android:id="@+id/view_mode"
            style="@style/ThinButton"
            android:text="@string/mode_sbs" />

        <Button
            android:id="@+id/snapshot"
            style="@style/ThinButton"
            android:text="@string/snapshot" />
    </LinearLayout>
</LinearLayout>
