<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-feature
        android:name="android.hardware.usb.host"
        android:required="true" />

    <!-- The glasses are a composite USB device containing a camera (UVC) and
         microphones (USB audio capture). Android 10+ only grants USB access
         to such a device if the app holds the matching runtime permissions,
         even though neither is used through Android's own camera/audio APIs. -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- snapshots use MediaStore on Android 10+; only older devices need this -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.camera.any" android:required="false" />
    <uses-feature android:name="android.hardware.microphone" android:required="false" />

    <application
        android:allowBackup="false"
        android:icon="@android:drawable/ic_menu_camera"
        android:label="@string/app_name"
        android:theme="@android:style/Theme.Material.NoActionBar">

        <activity
            android:name=".MainActivity"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden"
            android:exported="true"
            android:launchMode="singleTask"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- auto-launch (with implicit USB permission) when the glasses
                 are plugged in -->
            <intent-filter>
                <action android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED" />
            </intent-filter>
            <meta-data
                android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED"
                android:resource="@xml/device_filter" />
        </activity>

        <!-- QNN NPU/GPU access (Snapdragon). API 31+ hides vendor native libs
             from apps unless explicitly requested; these are listed in the
             device's /vendor/etc/public.libraries.txt, so this loads the REAL
             /vendor/lib64 copies (with their Binder/DSP-service and SELinux
             access intact) when QNN's libQnnHtp/libQnnGpu dlopen them. The
             correct, portable path instead of bundling the firmware libs into
             the APK. Ignored on API below 31 and on non-Qualcomm devices
             (required=false). libcdsprpc = FastRPC client for the Hexagon HTP;
             libOpenCL = the Adreno GPU backend. -->
        <uses-native-library android:name="libcdsprpc.so" android:required="false" />
        <uses-native-library android:name="libadsprpc.so" android:required="false" />
        <uses-native-library android:name="libOpenCL.so" android:required="false" />
    </application>

</manifest>
